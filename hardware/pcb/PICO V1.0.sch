<symbol name="CONN_01" urn="urn:adsk.eagle:symbol:37640/2" library_version="2">
<description>&lt;h3&gt;1 Pin Connection&lt;/h3&gt;</description>
<wire x1="3.81" y1="-2.54" x2="-2.54" y2="-2.54" width="0.4064" layer="94"/>
